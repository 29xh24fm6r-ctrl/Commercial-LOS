# Commercial Lending LOS — environment flags (example).
# Copy to .env.local for local dev. Vite only exposes VITE_-prefixed
# vars to the client bundle; everything else is SERVER-ONLY.

# ─── Email lane (existing) ───────────────────────────────────────────
# DRY_RUN (default) | LIVE | HANDOFF
VITE_EMAIL_MODE=DRY_RUN

# ─── Copilot connector (SPEC-COPILOT-LIVE-CONNECTOR) ─────────────────
# Client-visible, NON-SECRET mode + provider flags. The app defaults to
# not_configured when these are unset.
#   COPILOT_MODE:     not_configured | live_read_only | proposal_only | disabled
#   COPILOT_PROVIDER: default | azure_openai | copilot_studio | mock
VITE_COPILOT_MODE=not_configured
VITE_COPILOT_PROVIDER=default

# ─── Azure OpenAI — SERVER-ONLY. NEVER prefix these with VITE_. ──────
# The client never reads these. Live model calls are made server-side
# (e.g. a Dataverse custom API / connector — see
# docs/PHASE_130B_COPILOT_CONNECTOR_READINESS.md). Until that transport
# is wired, azure_openai/copilot_studio resolve to `disabled`.
# Use a managed identity instead of a raw key where possible.
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_KEY=        # prefer managed identity; never ship to client
